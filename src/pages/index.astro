---
import Layout from '../layouts/Layout.astro'
import ProjectItem from '../components/ProjectItem.astro'
import ExternalLink from '../components/ExternalLink.astro'
---

<Layout>
  <div
    class='mx-auto flex min-h-[60vh] max-w-2xl flex-col justify-center gap-12'
  >
    <header class='space-y-6'>
      <h1
        class='font-mono text-4xl font-bold tracking-tight text-foreground sm:text-5xl'
      >
        Alexander Saavedra
      </h1>
      <div
        class='space-y-4 text-lg leading-relaxed text-muted-foreground sm:text-xl'
      >
        <p>
          Ingeniero de Software con base en <ExternalLink
            href='https://www.google.com/maps/place/Barakaldo,+Bizkaia'
            class='font-mono text-foreground hover:underline'
          >
            Barakaldo, Bizkaia.
          </ExternalLink> Trabajo en <ExternalLink
            href='https://lookiero.es'
            class='font-mono text-foreground hover:underline'
          >
            Lookiero
          </ExternalLink> — React, TypeScript, Clean Architecture y DDD aplicados
          a un monorepo de frontend a escala real.
        </p>
        <p>
          Construyo open source, cacharro con servidores propios y aplico
          ingeniería al desarrollo con IA: memoria persistente entre sesiones y
          SDD para cambios con impacto arquitectónico.
        </p>
      </div>
    </header>

    <div class='space-y-6'>
      <h2 class='text-sm font-medium text-muted-foreground'>
        Proyectos personales
      </h2>
      <div class='grid gap-6 sm:grid-cols-2'>
        <ProjectItem
          title='spotiarr'
          href='https://github.com/mralexsaavedra/spotiarr'
        >
          Descargador de Spotify self-hosted con integración Jellyfin/Plex.
          Stack completo en <span class='font-mono text-foreground'
            >TypeScript</span
          >
          — <span class='font-mono text-foreground'>Clean Architecture</span>,
          cola asíncrona y sincronización en tiempo real.
        </ProjectItem>

        <ProjectItem
          title='spotdl-bot'
          href='https://github.com/mralexsaavedra/spotdl-bot'
        >
          Bot de Telegram para descargar música de Spotify. Escrito en <span
            class='font-mono text-foreground'>Python</span
          > y mencionado en el podcast <ExternalLink
            href='https://www.desdeelreloj.com/e1145/'
            class='font-mono text-foreground hover:underline'
          >
            Desde el Reloj.
          </ExternalLink>
        </ProjectItem>

        <ProjectItem
          title='jellytube'
          href='https://github.com/mralexsaavedra/jellytube'
        >
          Microservicio en <span class='font-mono text-foreground'
            >TypeScript</span
          >
          que integra YouTube con Jellyfin/Plex sin almacenamiento local.
        </ProjectItem>

        <ProjectItem title='koma' href='https://github.com/mralexsaavedra/koma'>
          Gestor de cómics self-hosted. Arquitectura <span
            class='font-mono text-foreground'>Clean Architecture</span
          > estricta — core sin dependencias de framework, completamente testable
          en aislamiento.
        </ProjectItem>
      </div>
    </div>

    <footer class='flex items-center gap-6 pt-4'>
      <ExternalLink
        href='https://github.com/mralexsaavedra'
        label='GitHub'
        class='font-mono font-medium text-muted-foreground transition-colors hover:text-foreground'
      >
        GitHub
      </ExternalLink>
      <ExternalLink
        href='https://www.linkedin.com/in/mralexsaavedra'
        label='LinkedIn'
        class='font-mono font-medium text-muted-foreground transition-colors hover:text-foreground'
      >
        LinkedIn
      </ExternalLink>
      <ExternalLink
        href='https://x.com/mralexsaavedra'
        label='X'
        class='font-mono font-medium text-muted-foreground transition-colors hover:text-foreground'
      >
        X
      </ExternalLink>
      <ExternalLink
        href='/cv.pdf'
        label='CV'
        class='font-mono font-medium text-muted-foreground transition-colors hover:text-foreground'
      >
        CV
      </ExternalLink>
    </footer>
  </div>
</Layout>
